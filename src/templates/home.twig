{% extends "base.twig" %}

{% block content %}
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1 class="hero-heading" data-headings='{{ t.hero.headings|json_encode }}'>{{ t.hero.headings[0] }}</h1>
            <p class="hero-subtitle">{{ t.hero.subtitle }}</p>
            <div class="hero-cta">
                <a href="{{ lang == 'da' ? '/projekter' : '/en/projects' }}" class="btn btn-outline">{{ t.hero.cta_work }}</a>
                <a href="{{ lang == 'da' ? '/kontakt' : '/en/contact' }}" class="btn btn-outline">{{ t.hero.cta_contact }}</a>
            </div>
        </div>
        <div class="hero-image">
            <img src="/public/images/profile.png" alt="Mario Festersen">
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">{{ t.sections.what_i_work_with }}</h2>
        <div class="areas-grid">
            <div class="area-card">
                <h3>{{ t.areas.data_engineering.title }}</h3>
                <p>{{ t.areas.data_engineering.desc }}</p>
            </div>
            <div class="area-card">
                <h3>{{ t.areas.machine_learning.title }}</h3>
                <p>{{ t.areas.machine_learning.desc }}</p>
            </div>
            <div class="area-card">
                <h3>{{ t.areas.data_analytics.title }}</h3>
                <p>{{ t.areas.data_analytics.desc }}</p>
            </div>
            <div class="area-card">
                <h3>{{ t.areas.fullstack.title }}</h3>
                <p>{{ t.areas.fullstack.desc }}</p>
            </div>
            <div class="area-card">
                <h3>{{ t.areas.automation.title }}</h3>
                <p>{{ t.areas.automation.desc }}</p>
            </div>
            <div class="area-card">
                <h3>{{ t.areas.communication.title }}</h3>
                <p>{{ t.areas.communication.desc }}</p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="section-title">{{ t.sections.featured_projects }}</h2>
        <div class="project-grid">
            {% for project in projects %}
            <article class="project-card">
                {% if project.featured_image %}
                <img src="{{ project.featured_image }}" alt="{{ project.title.rendered }}" class="project-card-image">
                {% endif %}
                <div class="project-card-body">
                    <h3><a href="{{ (lang == 'da' ? '' : '/en') ~ '/projects/' ~ project.slug }}">{{ project.title.rendered|raw }}</a></h3>
                    <p>{{ project.excerpt.rendered|striptags|truncate(120) }}</p>
                </div>
            </article>
            {% else %}
            <p class="empty-state">{{ t.empty.projects }}</p>
            {% endfor %}
        </div>
        {% if projects|length > 0 %}
        <p class="section-more"><a href="{{ lang == 'da' ? '/projekter' : '/en/projects' }}">{{ t.sections.view_all_projects }} &rarr;</a></p>
        {% endif %}
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <h2 class="section-title">{{ t.sections.latest_posts }}</h2>
        <div class="post-list">
            {% for post in posts %}
            <article class="post-preview">
                <time datetime="{{ post.date }}">{{ post.date|date("F j, Y") }}</time>
                <h3><a href="{{ (lang == 'da' ? '' : '/en') ~ '/blog/' ~ post.slug }}">{{ post.title.rendered|raw }}</a></h3>
                <p>{{ post.excerpt.rendered|striptags|truncate(160) }}</p>
            </article>
            {% else %}
            <p class="empty-state">{{ t.empty.posts }}</p>
            {% endfor %}
        </div>
        {% if posts|length > 0 %}
        <p class="section-more"><a href="{{ lang == 'da' ? '/blog' : '/en/blog' }}">{{ t.sections.read_all_posts }} &rarr;</a></p>
        {% endif %}
    </div>
</section>
{% endblock %}
