<!DOCTYPE html>
<html lang="{{ lang }}" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title }} | {{ site_name }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ site_name }} - {{ site_tagline }}{% endblock %}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ page_title }} | {{ site_name }}">
    <meta property="og:type" content="website">
    <meta property="og:description" content="{% block og_description %}{{ site_tagline }}{% endblock %}">

    <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a href="{{ lang == 'da' ? '/' : '/en/' }}" class="site-logo" aria-label="{{ site_name }}">
                <svg class="logo-svg" viewBox="0 0 520 90" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <g fill="currentColor">
                        <path d="M10 75 V15 H25 L45 45 L65 15 H80 V75 H65 V35 L45 60 L25 35 V75 Z" />
                        <rect x="95" y="15" width="50" height="14" />
                        <rect x="95" y="39" width="35" height="14" />
                        <rect x="95" y="62" width="17" height="13" />
                    </g>
                    <g fill="currentColor" font-family="Inter, Arial, sans-serif" font-weight="600">
                        <text x="170" y="42" font-size="26" letter-spacing="1.5">DATA &amp;</text>
                        <text x="170" y="72" font-size="26" letter-spacing="1.5">DEVELOPMENT</text>
                    </g>
                </svg>
            </a>
            <nav class="site-nav">
                <ul class="nav-links">
                    <li><a href="{{ lang == 'da' ? '/' : '/en/' }}" {% if page_title == 'Home' %}class="active"{% endif %}>{{ t.nav.home }}</a></li>
                    <li><a href="{{ lang == 'da' ? '/projekter' : '/en/projects' }}" {% if page_title == 'Projects' %}class="active"{% endif %}>{{ t.nav.projects }}</a></li>
                    <li><a href="{{ lang == 'da' ? '/blog' : '/en/blog' }}" {% if page_title == 'Blog' %}class="active"{% endif %}>{{ t.nav.blog }}</a></li>
                    <li><a href="{{ lang == 'da' ? '/om' : '/en/about' }}" {% if page_title == 'About' %}class="active"{% endif %}>{{ t.nav.about }}</a></li>
                    <li><a href="{{ lang == 'da' ? '/kontakt' : '/en/contact' }}" {% if page_title == 'Contact' %}class="active"{% endif %}>{{ t.nav.contact }}</a></li>
                </ul>
            </nav>
            <div class="lang-switcher">
                <a href="{{ lang == 'da' ? '/' : alt_url }}" class="lang-flag {% if lang == 'da' %}active{% endif %}" title="Dansk">&#127465;&#127472;</a>
                <a href="{{ lang == 'en' ? '/en/' : alt_url }}" class="lang-flag {% if lang == 'en' %}active{% endif %}" title="English">&#127468;&#127463;</a>
            </div>
            <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                <span class="theme-icon-light">&#9789;</span>
                <span class="theme-icon-dark">&#9788;</span>
            </button>
            <button class="nav-toggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <p>&copy; {{ current_year }} {{ site_name }}. {{ t.footer.rights }}</p>
                <div class="footer-links">
                    <a href="https://github.com/Rambuk01" target="_blank" rel="noopener">GitHub</a>
                    <a href="https://linkedin.com/in/mariofestersen" target="_blank" rel="noopener">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="/public/js/theme.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
