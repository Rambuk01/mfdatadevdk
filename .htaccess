RewriteEngine On

# Pass through requests to WordPress CMS
RewriteRule ^cms/ - [L]

# Pass through requests to static files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route everything else to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
