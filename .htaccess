RewriteEngine On
RewriteBase /

# Pass through requests to WordPress CMS
RewriteRule ^cms/ - [L]

# Pass through requests to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else to index.php
RewriteRule ^(.*)$ index.php [QSA,L]
